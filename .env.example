# Low-Carbon Material Finder — Environment Variables
# Copy this file to .env.local for local development
# Add these as Environment Variables in Vercel Dashboard for production

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Project URL (safe to expose in frontend)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — used by API routes and frontend (read-only by default)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — used ONLY by seed-db.js (never expose in frontend!)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── EC3 (Building Transparency) ───────────────────────────────────────────────
# Used by scripts/update-db.js for live plant sync
# Get from: buildingtransparency.org → Account → API Keys
EC3_API_KEY=
